{
  "name": "career-arc-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync:data": "node scripts/sync-data.mjs",
    "sync:data:generate": "node scripts/sync-data.mjs --generate",
    "sync:data:fixture": "node scripts/write-fixture-data.mjs",
    "dev": "vite",
    "build": "npm run sync:data && tsc -b && vite build",
    "build:with-data": "npm run sync:data:generate && tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
